# 1. The Triggers: When should this run?
on:
  push:
    branches:
      - main
    paths:
      - 'train.py'           # Only triggers if you actually edit the training logic!
  repository_dispatch:
    types: [drift_alert_retrain] # This is the exact phrase our drift detector broadcasts
  workflow_dispatch:         # For manual testing

# 2. The Job: What does the robot engineer do?
jobs:
  rebuild-ai:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.8'

      # Log into your Azure environment using a hidden GitHub Secret
      - name: Azure Login
        uses: azure/login@v1
        with:
          creds: ${{ secrets.AZURE_CREDENTIALS }}
          
      - name: Install Dependencies & Azure CLI
        run: |
          python -m pip install --upgrade pip
          pip install azure-ai-ml azure-identity
          az extension add -n ml -y

      # Run your existing scripts to train Version 2 and swap the live endpoint!
      - name: Train and Deploy New Model
        run: |
          echo "🚀 Triggering Training Job..."
          python submit_v2.py
          
          echo "🌐 Updating Live API to Version 2..."
          python deploy.py
