name: sklearn-1.5-with-xgboost
channels:
  - conda-forge
  - defaults
dependencies:
  - python=3.10
  - pip
  - pip:
      - setuptools             # Fixes 'pkg_resources' error
      - mlflow==2.11.3
      - azureml-mlflow
      - xgboost                # ADDED THIS
      - scikit-learn==1.5.0
      - pandas
      - numpy
      - joblib