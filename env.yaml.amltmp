name: insurance_custom_env_v7
channels:
  - conda-forge
  - defaults
dependencies:
  - python=3.10
  - pip
  - pip:
      - setuptools<70.0.0        # THE CRITICAL FIX: Restores pkg_resources
      - mlflow==2.11.3
      - mlflow-skinny==2.11.3
      - azureml-mlflow
      - azure-identity
      - azure-mgmt-core
      - scikit-learn
      - xgboost
      - pandas
      - numpy
      - joblib